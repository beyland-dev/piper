{
  "name": "piper",
  "version": "0.1.0",
  "description": "Declarative orchestration framework for CLI-driven coding workflows",
  "author": "Hawk Ticehurst",
  "license": "MIT",
  "type": "module",
  "bin": {
    "piper": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "piper": "tsx src/cli/index.ts"
  },
  "keywords": [
    "agents",
    "typescript",
    "workflow",
    "pi",
    "copilot"
  ],
  "dependencies": {
    "esbuild": "^0.25.5",
    "posthog-node": "5.38.5"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
